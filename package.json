{
  "name": "@agent/monorepo",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "convex": "1.34.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "dev": "bun --env-file=.env.local scripts/dev.ts",
    "setup": "bun --env-file=.env.local scripts/setup.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.6",
    "convex": "^1.34.1",
    "zod": "^4.3.6"
  }
}
