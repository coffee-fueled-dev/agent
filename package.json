{
  "name": "@agent/monorepo",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "convex": "1.34.0"
  },
  "devDependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "@types/bun": "latest"
  },
  "scripts": {
    "dev": "bun run dev:convex & bun run dev:embedding-server & bun run dev:telemetry & bun run dev:filesystem",
    "dev:convex": "bun run scripts/dev-convex.ts",
    "dev:convex:raw": "bun run scripts/convex.ts dev",
    "codegen:convex": "bun run scripts/convex.ts codegen",
    "dev:embedding-server": "bun run scripts/dev-app.ts embedding-server @agent/embedding-server dev",
    "dev:telemetry": "bun run scripts/dev-app.ts telemetry @agent/telemetry dev",
    "dev:filesystem": "bun run scripts/dev-app.ts filesystem @agent/filesystem dev",
    "seed:chat-token": "bun run scripts/seed-chat-token.ts",
    "typecheck": "bun run typecheck:convex",
    "typecheck:convex": "bunx tsc --noEmit -p convex/tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^2",
    "@biomejs/biome": "^2.4.6",
    "@convex-dev/agent": "^0.3.2",
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/geospatial": "^0.2.1",
    "@convex-dev/rag": "^0.7.2",
    "@convex-dev/sharded-counter": "^0.2.0",
    "@convex-dev/workflow": "^0.3.7",
    "@convex-dev/workpool": "^0.4.6",
    "@google/genai": "^1.46.0",
    "ai": "^5.0.82",
    "bash-parser": "^0.5.0",
    "convex": "1.34.0",
    "convex-helpers": "^0.1.114",
    "pca-js": "^2.0.6",
    "umap-js": "^1.4.0",
    "zod": "^4.3.6"
  }
}
