{
  "name": "@agent/monorepo",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "convex": "1.34.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/parse-gitignore": "^1.0.2",
    "minimatch": "^10.2.5",
    "parse-gitignore": "^2.0.0"
  },
  "scripts": {
    "dev": "bun --env-file=.env.local scripts/dev.ts",
    "configure": "bun --env-file=.env.local scripts/configure.ts",
    "context": "bun run scripts/context.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@agent/config": "workspace:*",
    "@biomejs/biome": "^2.4.6",
    "@ngrok/ngrok": "^1.7.0",
    "convex": "^1.34.1",
    "zod": "^4.3.6"
  }
}
