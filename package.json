{
  "name": "@agent/monorepo",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "dev:convex": "bun run scripts/dev-convex.ts",
    "dev:convex:raw": "bunx convex dev",
    "dev:chat": "bun --filter @agent/chat dev",
    "dev:telemetry": "bun --filter @agent/telemetry dev",
    "seed:chat-token": "bun run scripts/seed-chat-token.ts",
    "typecheck": "bun run typecheck:convex",
    "typecheck:convex": "bunx tsc --noEmit -p convex/tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2",
    "@biomejs/biome": "^2.4.6",
    "@convex-dev/agent": "^0.3.2",
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/geospatial": "^0.2.1",
    "ai": "^5.0.82",
    "convex": "^1.33.1",
    "convex-helpers": "^0.1.114",
    "zod": "^4.3.6"
  }
}
