# Copy to `.env.local` and fill in values. Root `package.json` loads `.env.local` for `bun run dev` / `bun run setup`.
# Do not commit `.env.local`.

# =============================================================================
# Convex CLI (local deployment)
# =============================================================================
# Written by `convex dev` / `convex dev --configure`. Used by the Convex CLI and backend.
CONVEX_DEPLOYMENT=
# HTTP URL of the Convex dev deployment (functions + database).
CONVEX_URL=
# HTTP URL for Convex-hosted HTTP endpoints (site) in local dev, if used.
CONVEX_SITE_URL=

# =============================================================================
# Monorepo dev orchestration — `scripts/dev.ts`
# =============================================================================
# Fixed before Convex starts so `EXECUTOR_URL` can be set without waiting for apps.
# Mapped to each app’s `PORT` (agent default 3000, executor default 3010).
APPS_AGENT_HOST=
APPS_AGENT_PORT=
APPS_EXECUTOR_HOST=
APPS_EXECUTOR_PORT=

# =============================================================================
# Convex “dashboard” environment — `scripts/convex.ts` → `convex env set`
# =============================================================================
# These are pushed to the linked Convex deployment (same names as in Convex dashboard).
# Also referenced from `apps/backend/convex/` via `process.env` in queries/actions.
# For documentation only, the same keys may be listed in `apps/backend/.env.convex` — keep values in sync when editing.
#
# Google Gemini (backend tools, embeddings, URL context, etc.).
GOOGLE_GENERATIVE_AI_API_KEY=
# OpenAI (backend models / tools where configured).
OPENAI_API_KEY=
# Base URL of the embedding HTTP service (executor exposes this in dev).
EMBEDDING_SERVER_URL=
# Shared secret between Convex and the embedding binary endpoint (`convex/filesEnv.ts`, executor embedding routes).
BINARY_EMBEDDING_SECRET=
# Base URL of the executor app (shell + browser automation). `scripts/dev.ts` sets this from APPS_EXECUTOR_* unless overridden.
EXECUTOR_URL=
# Feature flags read in Convex (`apps/backend/convex/env/executor.ts`, runShell / automateBrowserTask).
SHELL_EXECUTOR_ENABLED=
BROWSER_EXECUTOR_ENABLED=
# Browserbase: remote browser sessions (`searchWeb`, Stagehand CUA, `apps/backend/convex/env/browserbase.ts`).
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Optional: default Gemini model for `queryUrl` URL-context + Google Search (`apps/backend/convex/env/models.ts`).
# QUERY_URL_GEMINI_MODEL=
# Optional: rewrite origin for Convex storage URLs when tunneling (`STORAGE_PUBLIC_TUNNEL_ORIGIN`).
STORAGE_PUBLIC_TUNNEL_ORIGIN=
# Optional: override Stagehand CUA model (`apps/backend/convex/env/browserbase.ts`, executor browser routes).
# BROWSERBASE_STAGEHAND_CUA_MODEL=

# =============================================================================
# Executor app — `apps/executor` (HTTP APIs for shell, embedding, browser)
# =============================================================================
# Host/port for the optional `@agent/filesystem` service if you run it; executor fs routes read these.
FILESYSTEM_HOST=
FILESYSTEM_PORT=
# Must match what Convex uses for `runShell` / browser auth (`apps/executor/src/routes/api/fs/env.ts`).
LOCAL_SHELL_SECRET=
# SQLite path for per-agent filesystem state (`getFilesystemDbPath`).
FILESYSTEM_AGENT_DB=
# URL Convex / tooling use to reach the local shell HTTP API (same host/port as filesystem service).
LOCAL_SHELL_URL=
# Enables local-agent-only routes when set to the string `true` (typo alias `LOACL_AGENT` also checked).
LOCAL_AGENT=

# Optional executor tuning (browser session retries) — see `apps/executor/src/routes/api/browser/rateLimitRetry.ts`.
# BROWSERBASE_SESSION_OUTER_MAX_ATTEMPTS=
# BROWSERBASE_SESSION_RETRY_BASE_MS=
# BROWSERBASE_SESSION_RETRY_MAX_MS=

# Optional embedding cache DB path (`apps/executor/src/routes/api/embedding/env.ts`).
# EMBEDDING_CACHE_DB=

# =============================================================================
# Tunnels (optional)
# =============================================================================
# Used if you run ngrok or similar alongside local dev (not read by core `scripts/`).
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# =============================================================================
# Agent web UI — `apps/agent` (Bun embeds `BUN_PUBLIC_*` at dev/build time)
# =============================================================================
# Must match `CONVEX_URL` / deployment the UI should talk to (`apps/agent/src/render-root.tsx`, Convex React client).
BUN_PUBLIC_CONVEX_URL=
# Opaque token the agent UI sends for account/thread APIs (same token must be accepted server-side).
BUN_PUBLIC_ACCOUNT_TOKEN=
