# Copy to repo root as `.env.local` and fill secrets.
# Root `package.json` uses `bun --env-file=.env.local`.
# First time: run `bun configure`, then `bun dev`.
# Authoritative schema and defaults: `packages/config` (`loadMonorepoConfig`).

# --- Convex (local deployment; often written by `convex dev`) ---
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# --- API keys ---
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Executor shared secrets (must match on BOTH sides) ---
# Use the same string for each secret in:
#   (1) Convex deployment env — `convex env set` / what the dev script pushes, and
#   (2) The executor process — typically repo-root `.env.local` when running locally.
# Convex sends these when it calls the executor HTTP APIs; the executor checks them on every request.
FILE_EMBEDDING_SECRET=
SHELL_EXECUTOR_SECRET=
BROWSER_EXECUTOR_SECRET=

# --- Agent UI (Bun embeds at dev/build) ---
BUN_PUBLIC_CONVEX_URL=
BUN_PUBLIC_ACCOUNT_TOKEN=

# --- Listen addresses (optional; defaults in packages/config/src/defaults.ts) ---
# AGENT_LISTEN_HOST=127.0.0.1
# AGENT_LISTEN_PORT=3000
# EXECUTOR_LISTEN_HOST=0.0.0.0
# EXECUTOR_LISTEN_PORT=3010

# --- Public executor URL for Convex (defaults: http://127.0.0.1:3010) ---
# Set when the executor is on another host or behind a tunnel:
# TOOLING_PUBLIC_ORIGIN=https://your-tunnel.example
# Or build from parts:
# TOOLING_PUBLIC_SCHEME=http
# TOOLING_PUBLIC_HOST=127.0.0.1
# TOOLING_PUBLIC_PORT=3010

# --- Convex feature flags & optional models (string "true"/"false") ---
# SHELL_EXECUTOR_ENABLED=true
# BROWSER_EXECUTOR_ENABLED=true
# QUERY_URL_GEMINI_MODEL=
# BROWSERBASE_STAGEHAND_CUA_MODEL=

# --- Storage URLs for LLMs (Convex `applyPublicTunnelOrigin`) ---
# Empty: no rewrite. Literal https origin: set Convex env to that value (no local tunnel).
# `auto`: after Convex dev is ready, start ngrok to CONVEX_URL origin and set Convex env to the public URL.
# STORAGE_PUBLIC_TUNNEL_ORIGIN=
# STORAGE_PUBLIC_TUNNEL_ORIGIN=auto
# STORAGE_PUBLIC_TUNNEL_ORIGIN=https://my-static-ngrok.example

# --- Executor local paths (optional) ---
# FILESYSTEM_AGENT_DB=.sqlite/agent-filesystem.sqlite
# EMBEDDING_CACHE_DB=.sqlite/embedding-cache.sqlite
# LOCAL_AGENT=true

# --- ngrok (only when STORAGE_PUBLIC_TUNNEL_ORIGIN=auto) ---
# NGROK_AUTHTOKEN=
# NGROK_DOMAIN=
# Advanced: if file URLs use a different host than CONVEX_URL, set upstream origin/URL:
# STORAGE_TUNNEL_UPSTREAM=
